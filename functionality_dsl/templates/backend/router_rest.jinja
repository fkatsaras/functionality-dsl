# app/api/routers/{{ entity.name | lower }}.py
import time
import logging
from typing import List, Any, Dict

from fastapi import APIRouter, HTTPException, Request

from app.core.http import get_http_client
from app.core.utils import resolve_headers
from app.core.logging import set_request_id
from app.core.expressions import compile_safe
from app.core.computed import DSL_FUNCTION_REGISTRY as dsl_funcs, VEC_HELPERS

from app.domain.models import {{ entity.name }}

logger = logging.getLogger("fdsl.router.{{ entity.name }}")
router = APIRouter(
    prefix="/api/entities/{{ entity.name | lower }}",
    tags=["{{ entity.name }}"],
)

# Upstream configuration
_UPSTREAM_URL = "{{ entity.source.url }}"
_METHOD = "{{ (entity.source.verb or 'GET')|upper }}"
_HEADERS = resolve_headers([
{% for h in entity.source.headers | default([], true) -%}
    ("{{ h.key }}", "{{ h.value }}"),
{% endfor -%}
])

# WHERE filter (precompiled expr)
{% if entity._where_py %}
_WHERE = compile_safe({{ entity._where_py | tojson }})
{% else %}
_WHERE = None
{% endif %}


@router.get("/", response_model=List[{{ entity.name }}])
async def list_{{ entity.name | lower }}(request: Request):
    rid = getattr(request.state, "request_id", None)
    if rid: set_request_id(rid)

    client = get_http_client()
    t0 = time.monotonic()

    try:
        r = await client.request(_METHOD, _UPSTREAM_URL, headers=_HEADERS)
        elapsed = (time.monotonic() - t0) * 1000.0

        if r.status_code >= 400:
            logger.warning("upstream_error", extra={
                "entity": "{{ entity.name }}",
                "status": r.status_code,
                "elapsed_ms": round(elapsed, 2),
            })
            raise HTTPException(status_code=502, detail={"upstream_status": r.status_code, "body": r.text})

        data = r.json()
        rows: List[{{ entity.name }}] = []

        print('AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA')
        print('Entity {{ entity.name }} gets data:')
        print(str(data))
        print('AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA')

        for raw in (data if isinstance(data, list) else [data]):
            row: Dict[str, Any] = {}
            {% for attr in entity.attributes %}
            row["{{ attr.name }}"] = raw.get("{{ attr.name }}") if isinstance(raw, dict) else raw
            {% endfor %}

            if _WHERE:
                ok = bool(eval(_WHERE, {"__builtins__": {}, "dsl_funcs": dsl_funcs, **VEC_HELPERS}, {"row": row}))
                if not ok:
                    continue

            rows.append({{ entity.name }}(**row))

        print('AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA')
        print('Entity {{ entity.name }} gets data:')
        print(str(rows))
        print('AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA')

        logger.info("ok", extra={"entity": "{{ entity.name }}", "rows": len(rows), "elapsed_ms": round(elapsed, 2)})
        return rows

    except Exception:
        logger.exception("router_error", extra={"entity": "{{ entity.name }}"})
        raise
