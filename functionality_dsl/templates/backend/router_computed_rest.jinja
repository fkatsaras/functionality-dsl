# app/api/routers/{{ entity.name | lower }}.py
from typing import List, Any, Dict
from fastapi import APIRouter, HTTPException

from app.core.http import get_http_client
from app.core.expressions import compile_safe
from app.core.computed import DSL_FUNCTION_REGISTRY as dsl_funcs, VEC_HELPERS

from app.domain.models import {{ entity.name }}

router = APIRouter(
    prefix="/api/entities/{{ entity.name | lower }}",
    tags=["{{ entity.name }}"],
)

# REST + entity inputs
_INPUTS = [
{%- for it in rest_inputs %}
    {"alias": "{{ it.alias }}", "url": "{{ it.url }}", "headers": {{ (it.headers or {}) | tojson }}},
{%- endfor %}
{%- for it in entity_inputs %}
    {"alias": "{{ it.alias }}", "url": "http://{{ server.host }}:{{ server.port }}/api/entities/{{ it.target_name | lower }}/"},
{%- endfor %}
]

# Attribute expressions
_COMPILED = {
{%- for attr in computed_attrs %}
    "{{ attr.name }}": compile_safe({{ attr.pyexpr | tojson }}),
{%- endfor %}
}

# WHERE filter
{% if entity._where_py %}
_WHERE = compile_safe({{ entity._where_py | tojson }})
{% else %}
_WHERE = None
{% endif %}


def expand_vectorized(out_row: dict) -> list[dict]:
    """Explode any list-valued fields into multiple rows."""
    list_fields = [k for k, v in out_row.items() if isinstance(v, list)]
    if not list_fields:
        return [out_row]

    n = max(len(out_row[k]) for k in list_fields)
    rows = []
    for i in range(n):
        row_i = {k: (v[i] if isinstance(v, list) and i < len(v) else v) for k, v in out_row.items()}
        rows.append(row_i)
    return rows


@router.get("/", response_model=List[{{ entity.name }}])
async def list_{{ entity.name | lower }}():
    client = get_http_client()

    # --- Fetch inputs ---
    ctx: Dict[str, Any] = {}
    for it in _INPUTS:
        r = await client.get(it["url"], headers=it.get("headers"))
        if r.status_code >= 400:
            raise HTTPException(status_code=502, detail={"upstream_status": r.status_code, "body": r.text})
        ctx[it["alias"]] = r.json()

    # --- Compute outputs ---
    out_row: Dict[str, Any] = {}
    for name, code in _COMPILED.items():
        out_row[name] = eval(code, {"__builtins__": {}, "dsl_funcs": dsl_funcs, **VEC_HELPERS}, {"ctx": ctx})

    rows = expand_vectorized(out_row)

    # --- WHERE filter ---
    result = []
    for row in rows:
        if _WHERE:
            ok = bool(eval(_WHERE, {"__builtins__": {}, "dsl_funcs": dsl_funcs, **VEC_HELPERS}, {"row": row, "ctx": ctx}))
            if not ok:
                continue
        result.append({{ entity.name }}(**row))

    return result
