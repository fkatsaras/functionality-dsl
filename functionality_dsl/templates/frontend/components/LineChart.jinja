{# expects props.x and props.y (string or array; y can be array or array-of-arrays) #}
{% set endpoint    = common.url %}
{% set ws_endpoint = common.wsUrl %}

{% set x_spec = props.get('x') %}
{% set y_spec = props.get('y') %}

<LineChart
  name="{{ common.name }}"
  {% if endpoint %}url="{{ endpoint }}"{% endif %}
  {% if ws_endpoint %}wsUrl="{{ ws_endpoint }}"{% endif %}
  xSpec={{ "{" }}{{ x_spec | tojson }}{{ "}" }}
  ySpec={{ "{" }}{{ y_spec | tojson }}{{ "}" }}
  {%- if props.get('xLabel') %} xLabel="{{ props.get('xLabel') }}"{% endif %}
  {%- if props.get('yLabel') %} yLabel="{{ props.get('yLabel') }}"{% endif %}
  {%- if props.get('windowSize') is not none %} windowSize={{ "{" }}{{ props.get('windowSize') }}{{ "}" }}{% endif %}
  {%- if props.get('refreshMs') is not none %} refreshMs={{ "{" }}{{ props.get('refreshMs') }}{{ "}" }}{% endif %}
  {%- if props.get('height') is not none %} height={{ "{" }}{{ props.get('height') }}{{ "}" }}{% endif %}
/>
